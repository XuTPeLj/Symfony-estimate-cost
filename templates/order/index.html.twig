{% extends 'base.html.twig' %}

{% set title = 'Заказы' %}
{% set description = '' %}

{% block body %}
<div class="container">
    <div class="user-info">
        <div>
            <strong>Пользователь:</strong> {{ app.user.email }}
        </div>
        <a href="{{ path('app_logout') }}" class="logout">Выйти</a>
    </div>

    <div class="form-section">
        <h2>Создание нового заказа</h2>

        {% for message in app.flashes('success') %}
            <div class="alert-success">{{ message }}</div>
        {% endfor %}

        {% if errors|length > 0 %}
            <div class="error">
                <strong>Ошибки в форме:</strong>
                <ul>
                    {% for error in errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {{ form_start(form) }}
        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {% if form.email.vars.errors|length > 0 %}
                <div class="error">
                    {% for error in form.email.vars.errors %}
                        <div>{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.service) }}
            {{ form_widget(form.service) }}
            {% if form.service.vars.errors|length > 0 %}
                <div class="error">
                    {% for error in form.service.vars.errors %}
                        <div>{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div id="price-info" class="price-info form-group">
            Стоимость услуги: <span id="price-value">-</span> руб.
        </div>

        <div class="form-group">
            {{ form_widget(form.submit) }}
        </div>
        {{ form_end(form) }}
    </div>

    {# СЕКЦИЯ СО СПИСКОМ ЗАКАЗОВ #}
    <div class="orders-section">
        <h2>Мои заказы</h2>

        {% if userOrders|length > 0 %}
            <div class="orders-list">
                {% for order in userOrders %}
                    <div class="order-item">
                        <div class="order-info">
                            <div class="order-service">
                                {{ order.service.name }}
                            </div>
                            <div class="order-email">
                                Email: {{ order.email }}
                            </div>
                            <div class="order-date">
                                Дата: {{ order.createdAt|date('d.m.Y H:i') }}
                            </div>
                        </div>
                        <div class="order-price">
                            {{ order.service.price|number_format(0, '.', ' ') }} руб.
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="no-orders">
                У вас пока нет заказов. Создайте первый заказ выше!
            </div>
        {% endif %}
    </div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const serviceSelect = document.getElementById('order_service');
        const priceSpan = document.getElementById('price-value');

        const servicePrices = {
        {% for service in services %}
        {{ service.id }}: {{ service.price }},
        {% endfor %}
    };

        function updatePrice() {
            const selectedServiceId = serviceSelect.value;
            if (selectedServiceId && servicePrices[selectedServiceId]) {
                priceSpan.textContent = servicePrices[selectedServiceId];
            } else {
                priceSpan.textContent = '-';
            }
        }

        serviceSelect.addEventListener('change', updatePrice);
        updatePrice(); // Вызываем при загрузке
    });
</script>
</div>
{% endblock %}
